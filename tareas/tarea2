  <div class="hero">
    <div class="hero-inner">
      <div class="hero-badge">Tarea 2 · Streamlit</div>
      <h1>Limpieza de <span>CSV</span></h1>
      <p>Aplicación web con Streamlit que permite subir un archivo .csv, detectar y eliminar filas nulas y duplicadas, y descargar el resultado limpio.</p>
    </div>
  </div>

  <main>

    <a href="index.html" class="back-link">← Volver al portafolio</a>

    <!-- CÓDIGO FUENTE -->
    <section>
      <div class="section-header">
        <h2>Código fuente — app.py</h2>
      </div>

      <div class="code-wrapper">
        <div class="code-header">
          <div class="code-dots">
            <i></i><i></i><i></i>
          </div>
          <span>app.py</span>
          <div class="tags" style="margin:0;">
            <span class="tag">Python</span>
            <span class="tag">Streamlit</span>
            <span class="tag">pandas</span>
          </div>
        </div>
        <pre><code><span class="im">import</span> <span class="va">streamlit</span> <span class="im">as</span> <span class="va">st</span>
<span class="im">import</span> <span class="va">pandas</span> <span class="im">as</span> <span class="va">pd</span>

<span class="va">st</span>.<span class="fn">set_page_config</span>(<span class="va">page_title</span><span class="op">=</span><span class="st">"My Streamlit App"</span>, <span class="va">page_icon</span><span class="op">=</span><span class="st">":rocket:"</span>, <span class="va">layout</span><span class="op">=</span><span class="st">"centered"</span>)

<span class="va">st</span>.<span class="fn">title</span>(<span class="st">"Sube un csv"</span>)
<span class="va">st</span>.<span class="fn">write</span>(<span class="st">"Sube un archivo .csv"</span>)
<span class="va">archivo</span> <span class="op">=</span> <span class="va">st</span>.<span class="fn">file_uploader</span>(<span class="st">"Upload a file"</span>, <span class="va">type</span><span class="op">=</span>[<span class="st">"csv"</span>])

<span class="kw">if</span> <span class="va">archivo</span> <span class="kw">is not</span> <span class="nm">None</span>:
    <span class="kw">try</span>:
        <span class="va">df</span> <span class="op">=</span> <span class="va">pd</span>.<span class="fn">read_csv</span>(<span class="va">archivo</span>)
        <span class="kw">if</span> <span class="va">df</span>.<span class="fn">empty</span>:
            <span class="va">st</span>.<span class="fn">error</span>(<span class="st">"El archivo está vacío, no es posible realizar limpieza de datos, favor de subir otro archivo"</span>)
        <span class="kw">else</span>:
            <span class="va">total_filas</span> <span class="op">=</span> <span class="fn">len</span>(<span class="va">df</span>)
            <span class="va">cols</span> <span class="op">=</span> [<span class="va">c</span> <span class="kw">for</span> <span class="va">c</span> <span class="kw">in</span> <span class="va">df</span>.<span class="va">columns</span> <span class="kw">if</span> <span class="va">c</span>.<span class="fn">lower</span>() <span class="op">!=</span> <span class="st">"id"</span>]
            <span class="va">filas_nulas</span> <span class="op">=</span> <span class="va">df</span>[<span class="va">df</span>.<span class="fn">isnull</span>().<span class="fn">any</span>(<span class="va">axis</span><span class="op">=</span><span class="nm">1</span>)]
            <span class="va">filas_duplicadas</span> <span class="op">=</span> <span class="va">df</span>[<span class="va">df</span>.<span class="fn">duplicated</span>(<span class="va">subset</span><span class="op">=</span><span class="va">cols</span>)]
            <span class="va">st</span>.<span class="fn">write</span>(<span class="va">f</span><span class="st">"Total de filas: </span><span class="op">{</span><span class="va">total_filas</span><span class="op">}</span><span class="st">"</span>)
            <span class="va">st</span>.<span class="fn">write</span>(<span class="va">f</span><span class="st">"Filas con valores nulos: </span><span class="op">{</span><span class="fn">len</span>(<span class="va">filas_nulas</span>)<span class="op">}</span><span class="st">"</span>)
            <span class="va">st</span>.<span class="fn">write</span>(<span class="va">f</span><span class="st">"Filas duplicadas (ignorando 'id'): </span><span class="op">{</span><span class="fn">len</span>(<span class="va">filas_duplicadas</span>)<span class="op">}</span><span class="st">"</span>)
            <span class="va">st</span>.<span class="fn">write</span>(<span class="st">"Ejemplos de filas con valores nulos:"</span>)
            <span class="va">st</span>.<span class="fn">write</span>(<span class="va">filas_nulas</span>.<span class="fn">head</span>(<span class="nm">5</span>))
            <span class="va">st</span>.<span class="fn">write</span>(<span class="st">"Ejemplos de filas duplicadas:"</span>)
            <span class="va">st</span>.<span class="fn">write</span>(<span class="va">filas_duplicadas</span>.<span class="fn">head</span>(<span class="nm">5</span>))
            <span class="va">df_limpio</span> <span class="op">=</span> <span class="va">df</span>.<span class="fn">dropna</span>().<span class="fn">drop_duplicates</span>(<span class="va">subset</span><span class="op">=</span><span class="va">cols</span>)

            <span class="va">filas_finales</span> <span class="op">=</span> <span class="fn">len</span>(<span class="va">df_limpio</span>)
            <span class="va">filas_borradas</span> <span class="op">=</span> <span class="va">total_filas</span> <span class="op">-</span> <span class="va">filas_finales</span>
            <span class="va">st</span>.<span class="fn">write</span>(<span class="st">"Limpieza realizada"</span>)
            <span class="va">st</span>.<span class="fn">write</span>(<span class="va">f</span><span class="st">"Filas eliminadas: </span><span class="op">{</span><span class="va">filas_borradas</span><span class="op">}</span><span class="st">"</span>)
            <span class="va">st</span>.<span class="fn">write</span>(<span class="va">f</span><span class="st">"Filas restantes: </span><span class="op">{</span><span class="va">filas_finales</span><span class="op">}</span><span class="st">"</span>)
            <span class="va">st</span>.<span class="fn">write</span>(<span class="st">"Primeras filas del archivo limpio:"</span>)
            <span class="va">st</span>.<span class="fn">write</span>(<span class="va">df_limpio</span>.<span class="fn">head</span>(<span class="nm">10</span>))
            <span class="va">st</span>.<span class="fn">download_button</span>(
                <span class="va">label</span><span class="op">=</span><span class="st">"Descargar archivo limpio"</span>,
                <span class="va">data</span><span class="op">=</span><span class="va">df_limpio</span>.<span class="fn">to_csv</span>(<span class="va">index</span><span class="op">=</span><span class="nm">False</span>).<span class="fn">encode</span>(<span class="st">"utf-8"</span>),
                <span class="va">file_name</span><span class="op">=</span><span class="st">"datos_limpios.csv"</span>,
                <span class="va">mime</span><span class="op">=</span><span class="st">"text/csv"</span>)
    <span class="kw">except</span> <span class="fn">Exception</span> <span class="kw">as</span> <span class="va">e</span>:
        <span class="va">st</span>.<span class="fn">error</span>(<span class="va">f</span><span class="st">"Error al leer el archivo: </span><span class="op">{</span><span class="va">e</span><span class="op">}</span><span class="st">"</span>)</code></pre>
      </div>
